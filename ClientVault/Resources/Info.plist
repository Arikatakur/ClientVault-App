<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>ClientVault</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- SwiftUI App lifecycle: single-scene, no storyboard. -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- iPhone-first, portrait primary. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UIUserInterfaceStyle</key>
	<string>Dark</string>

	<!-- Privacy usage strings. -->
	<key>NSFaceIDUsageDescription</key>
	<string>ClientVault uses Face ID to unlock your encrypted vault without typing your vault password.</string>

	<!-- Background mode for cross-device push (registration seam ships now; enabled when push lands). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>

	<!-- Export compliance: the app uses only standard, Apple-provided cryptography
	     (CryptoKit AES-GCM) to protect the user's own data, which qualifies for the
	     exemption. Revisit if non-standard crypto is ever added. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Google Sign-In. Replace both PLACEHOLDER values with the real client id and
	     its reversed form from the Google Cloud console (see docs/auth.md). AppConfig
	     treats a PLACEHOLDER GIDClientID as "not configured", so the Google button
	     errors gracefully until real values are set. -->
	<key>9238254790-t5ut5h8pmcfpq1hpuontrhns2q9tviel.apps.googleusercontent.com</key>
	<string>PLACEHOLDER.apps.googleusercontent.com</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.PLACEHOLDER</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
