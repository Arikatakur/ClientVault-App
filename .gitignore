# ─── macOS / editors ────────────────────────────────────────────────
.DS_Store
*.swp
.history
.idea/
*.iml
*.ipr
*.iws
# VS Code config is intentionally allowed; uncomment to ignore:
#.vscode/

# ─── Xcode ──────────────────────────────────────────────────────────
# Build / derived data
DerivedData/
build/
*.xcuserstate
*.xcuserdatad/
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# The Xcode project is GENERATED from project.yml by XcodeGen.
# Do not commit it — run `xcodegen generate` instead.
*.xcodeproj/
*.xcworkspace/

# ─── Swift Package Manager ──────────────────────────────────────────
.build/
.swiftpm/
Package.resolved

# ─── CocoaPods / Carthage (only if introduced later) ────────────────
Pods/
Carthage/Build/

# ─── Fastlane / code signing — NEVER commit secrets ─────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md
**/AuthKey*.p8
*.p8
*.p12
*.mobileprovision
*.cer
*.certSigningRequest

# ─── Secrets / local config ─────────────────────────────────────────
.env
.env.*
!.env.example
*.local.xcconfig
Secrets.xcconfig
amplify_outputs.json          # generated per-environment; provision via CI
amplifyconfiguration.json

# ─── Legacy Flutter archive (regenerable build artifacts only) ──────
legacy/flutter/build/
legacy/flutter/.dart_tool/
legacy/flutter/.flutter-plugins-dependencies
legacy/flutter/ios/Flutter/.last_build_id
