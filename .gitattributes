# Normalize line endings: store LF in the repo regardless of contributor OS.
* text=auto eol=lf

# Source & config are always LF (keeps CI shell scripts and YAML safe).
*.swift   text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.json    text eol=lf
*.plist   text eol=lf
*.entitlements text eol=lf
*.md      text eol=lf
*.sh      text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.pdf binary
*.p8  binary
*.p12 binary
