default_platform(:ios)

APP_IDENTIFIER = "org.clientvault.app".freeze
PROFILE_NAME = "match AppStore #{APP_IDENTIFIER}".freeze

platform :ios do
  before_all do
    # On CI, create a temporary keychain so match can install the signing identity.
    setup_ci if ENV["CI"]
  end

  desc "Generate and store signing assets in the match repo (run once / when they change)."
  lane :bootstrap_signing do
    match(type: "appstore", readonly: false, api_key: asc_api_key)
  end

  desc "Build the app and upload it to TestFlight."
  lane :beta do
    match(type: "appstore", readonly: true, api_key: asc_api_key)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: APP_IDENTIFIER,
      code_sign_identity: "Apple Distribution",
      profile_name: PROFILE_NAME,
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          APP_IDENTIFIER => PROFILE_NAME,
        },
      },
    )

    upload_to_testflight(
      api_key: asc_api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end

# App Store Connect API key, assembled from env + the decoded .p8 next to this file.
def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
    key_filepath: File.expand_path("AuthKey.p8", __dir__),
    in_house: false,
  )
end
