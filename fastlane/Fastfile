require "base64"

default_platform(:ios)

platform :ios do
  desc "Build and upload ClientVault to TestFlight"
  lane :testflight do
    setup_ci

    key_content =
      if ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s.length.positive?
        Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64"))
      else
        ENV.fetch("APP_STORE_CONNECT_API_KEY")
      end

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: key_content,
      is_key_content_base64: false
    )

    sh("xcodegen generate")

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ClientVault.xcodeproj",
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      profile_name: "match AppStore org.clientvault.app",
      targets: ["ClientVault"]
    )

    build_app(
      project: "ClientVault.xcodeproj",
      scheme: "ClientVault",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: "build/ios",
      output_name: "ClientVault.ipa",
      xcargs: "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios/ClientVault.ipa",
      skip_waiting_for_build_processing: true
    )
  end
end
