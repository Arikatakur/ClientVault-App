require "base64"

default_platform(:ios)

platform :ios do
  desc "Regenerate Match provisioning profiles (run once after capability changes)"
  lane :sync_certs do
    setup_ci

    key_content =
      if ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s.length.positive?
        Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64"))
      else
        ENV.fetch("APP_STORE_CONNECT_API_KEY")
      end

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: key_content,
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      readonly: false,
      force: true,
      api_key: api_key
    )
  end

  desc "Build and upload ClientVault to TestFlight"
  lane :beta do
    setup_ci

    repo_root = File.expand_path("..", __dir__)
    project_path = File.join(repo_root, "ClientVault.xcodeproj")
    output_directory = File.join(repo_root, "build/ios")
    ipa_path = File.join(output_directory, "ClientVault.ipa")

    key_content =
      if ENV["APP_STORE_CONNECT_API_KEY_BASE64"].to_s.length.positive?
        Base64.decode64(ENV.fetch("APP_STORE_CONNECT_API_KEY_BASE64"))
      else
        ENV.fetch("APP_STORE_CONNECT_API_KEY")
      end

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_content: key_content,
      is_key_content_base64: false
    )

    Dir.chdir(repo_root) do
      sh("xcodegen generate")
    end

    match(
      type: "appstore",
      readonly: true,
      api_key: api_key
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: project_path,
      team_id: ENV.fetch("APPLE_TEAM_ID"),
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore org.clientvault.app",
      targets: ["ClientVault"]
    )

    build_app(
      project: project_path,
      scheme: "ClientVault",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: output_directory,
      output_name: "ClientVault.ipa",
      xcargs: "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')} " \
              "CODE_SIGN_STYLE=Manual " \
              "CODE_SIGN_IDENTITY='Apple Distribution'"
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end
end
